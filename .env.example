# ─────────────────────────────────────────────
#  PropIntel — Environment Configuration
#  Copy this file to .env and fill in values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────


# ── AI / LLM ──────────────────────────────────
# Get from: https://platform.openai.com → API Keys → Create new secret key
# Format: starts with "sk-"
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which OpenAI model to use. Options:
#   gpt-4o          ← recommended (fast, smart, cost-effective)
#   gpt-4o-mini     ← fastest, cheapest, less detailed analysis
#   gpt-4-turbo     ← strong reasoning, slightly slower
LLM_MODEL=gpt-4o


# ── PROPERTY LISTING ENRICHMENT ──────────────
# Firecrawl scrapes Realtor.com, Zillow, Redfin to extract detailed
# listing data: price, beds/baths, sqft, HOA fees, property taxes,
# lot size, garage, days on market, property type, HVAC, description.
#
# OPTION A — Self-hosted (RECOMMENDED, no limits, free):
#   1. Run: bash scripts/setup-firecrawl.sh
#   2. Start: docker compose -f docker-compose.yml -f docker-compose.firecrawl.yml up --build -d
#   3. Set the URL below (leave FIRECRAWL_API_KEY empty):
FIRECRAWL_API_URL=http://localhost:3002
#
# OPTION B — Firecrawl cloud (easier, but rate-limited):
#   Get API key from: https://www.firecrawl.dev → Dashboard → API Keys
#   Format: starts with "fc-"
#   Free tier: 500 pages/month | Paid: $16/mo for 3,000 pages
#   Set key below and leave FIRECRAWL_API_URL empty:
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# OPTION C — Neither set:
#   PropIntel falls back to direct HTTP scrapers (Zillow/Redfin only,
#   fewer fields, may be blocked by anti-bot measures).


# ── FREE DATA APIs ────────────────────────────
# Census API key — FREE, instant signup
# Get from: https://api.census.gov/data/key_signup.html
# Fill in your name + email, key arrives in ~1 minute by email
# Format: 40-character hex string
CENSUS_API_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# All other data sources (FEMA, EPA, OSM, USGS) need NO key.


# ── DATABASE ──────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# If using docker-compose (default):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/propintel

# If using a hosted database (e.g. Supabase, Neon, Railway):
# DATABASE_URL=postgresql+asyncpg://myuser:mypassword@db.example.com:5432/propintel


# ── REDIS ─────────────────────────────────────
# Format: redis://HOST:PORT or rediss://HOST:PORT (TLS)

# If using docker-compose (default):
REDIS_URL=redis://localhost:6379

# If using Redis Cloud or Upstash:
# REDIS_URL=rediss://default:mypassword@my-redis.upstash.io:6379


# ── LOGGING ───────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
# Use DEBUG while developing to see all API calls
LOG_LEVEL=INFO
