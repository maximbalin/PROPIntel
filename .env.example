# ─────────────────────────────────────────────
#  PropIntel — Environment Configuration
#  Copy this file to .env and fill in values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────


# ── AI / LLM ──────────────────────────────────
# Get from: https://console.anthropic.com → API Keys → Create Key
# Format: starts with "sk-ant-api03-"
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx

# Which Claude model to use. Options:
#   claude-sonnet-4-20250514  ← recommended (fast, smart, cost-effective)
#   claude-opus-4-5           ← most capable, slower, more expensive
#   claude-haiku-4-5          ← fastest, cheapest, less detailed analysis
LLM_MODEL=claude-sonnet-4-20250514


# ── FREE DATA APIs ────────────────────────────
# Census API key — FREE, instant signup
# Get from: https://api.census.gov/data/key_signup.html
# Fill in your name + email, key arrives in ~1 minute by email
# Format: 40-character hex string
CENSUS_API_KEY=a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2

# All other data sources (FEMA, EPA, OSM, USGS) need NO key.


# ── DATABASE ──────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME

# If using docker-compose (default):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/propintel

# If using a hosted database (e.g. Supabase, Neon, Railway):
# DATABASE_URL=postgresql+asyncpg://myuser:mypassword@db.example.com:5432/propintel


# ── REDIS ─────────────────────────────────────
# Format: redis://HOST:PORT or rediss://HOST:PORT (TLS)

# If using docker-compose (default):
REDIS_URL=redis://localhost:6379

# If using Redis Cloud or Upstash:
# REDIS_URL=rediss://default:mypassword@my-redis.upstash.io:6379


# ── LOGGING ───────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
# Use DEBUG while developing to see all API calls
LOG_LEVEL=INFO
